<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>New Product</title>
</head>
<body>
  <h1>New Product</h1>
  <form action="/products/create" method="post">
    <label>Name</label>
    <input name="name" type="text" required>
    <br>
    <label>Price</label>
    <input name="price" type="number" step="0.01" required>
    <br>
    <button type="submit">Create</button>
  </form>
  <a href="/products">Back</a>
</body>
</html>
